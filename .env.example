# ─────────────────────────────────────────────────────────────────────────
# world_wide_project — .env.example
#
# DOCUMENTACION de las variables de entorno requeridas. SOLO NOMBRES +
# COMENTARIO. NUNCA pongas valores reales aqui ni en .env commiteado.
#
# Uso:
#   1. cp .env.example .env
#   2. rellena .env con valores REALES (gitignored, nunca se commitea)
#   3. en produccion, define estas variables en el entorno del hosting,
#      NO en ficheros del repo.
#
# Regla anti-fuga (vs TaxIA): jamas un secreto en una string de comando de
# la allow-list de settings.json/settings.local.json.
# ─────────────────────────────────────────────────────────────────────────

# --- Turso (persistencia historica / time-series) ---
# URL de la base de datos libsql (ej. libsql://<db>-<org>.turso.io)
TURSO_DATABASE_URL=
# Token de auth de Turso (sensible)
TURSO_AUTH_TOKEN=

# --- Router LLM local-first: PROVIDER_CHAIN = ollama -> groq -> claude ---
# Ollama (local, primer eslabon; normalmente sin clave)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Groq (bulk-classify; clave necesaria si se usa este eslabon)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Anthropic / Claude (briefing diario + razonamiento de convergencia; 1-2 calls/dia)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Backend / server.ts ---
# Puerto del backend unico (server.ts)
PORT=8000
# Origenes permitidos para CORS / origin-check (coma-separados)
ALLOWED_ORIGINS=http://localhost:5173
# Entorno de ejecucion
NODE_ENV=development

# --- Frontend (Vite + React + MapLibre) ---
# Base URL del backend que consume packages/web (prefijo VITE_ = expuesto al cliente)
VITE_API_BASE_URL=http://localhost:8000
# Estilo/tiles de MapLibre (URL de estilo; usar uno sin clave o tu propia clave)
VITE_MAP_STYLE_URL=

# --- Conectores de fuentes (ZERO-KEY-FIRST: la mayoria funciona sin clave) ---
# Solo rellena las que tu fuente requiera. Verifica los ToS antes de añadir.
# Finanzas (ej. proveedor de markets con clave opcional)
FINANCE_API_KEY=
# Geo / eventos (ej. ACLED requiere registro; GDELT es keyless)
GEO_API_KEY=
ACLED_API_KEY=
ACLED_EMAIL=
# Educacion (ej. datasets abiertos; normalmente keyless)
EDU_API_KEY=

# --- User-Agent para fetch de conectores (buena practica / cumplimiento de ToS) ---
CONNECTOR_USER_AGENT=world_wide_project/0.1 (+https://example.com)
